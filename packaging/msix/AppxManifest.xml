<?xml version="1.0" encoding="utf-8"?>
<!--
  MSIX manifest for the Microsoft Store build of Mushak.

  BEFORE BUILDING, replace the two REPLACEME placeholders in <Identity>
  with the exact values from Partner Center:
    Product identity page > Package/Identity/Name   -> Name=
    Product identity page > Package/Identity/Publisher (CN=...) -> Publisher=
  These must match Partner Center character-for-character or the upload is
  rejected. See docs/ms-store-submission.md (kept locally, not committed).

  The <Version> last digit MUST stay 0 for Store packages; bump the first three
  to match the app version (e.g. 0.0.3.0). The build script substitutes it.
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap5="http://schemas.microsoft.com/appx/manifest/uap/windows10/5"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap5 rescap">

  <!-- REPLACEME below: swap in the Partner Center identity before submitting. -->
  <Identity
    Name="REPLACEME.Mushak"
    Publisher="CN=REPLACEME"
    Version="0.0.0.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Mushak</DisplayName>
    <PublisherDisplayName>Divyang Chauhan</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop"
                        MinVersion="10.0.19041.0"
                        MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="Mushak"
                 Executable="mushak.exe"
                 EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Mushak"
        Description="Lightweight replacement for Logitech Options+ for the MX Master 2S"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png" />
      </uap:VisualElements>

      <Extensions>
        <!-- Start-with-Windows for the packaged build. TaskId must match
             STARTUP_TASK_ID in src/startup.rs. Starts disabled; the app calls
             RequestEnableAsync when the user turns the tray option on. -->
        <uap5:Extension
          Category="windows.startupTask"
          Executable="mushak.exe"
          EntryPoint="Windows.FullTrustApplication">
          <uap5:StartupTask
            TaskId="MushakStartup"
            Enabled="false"
            DisplayName="Mushak" />
        </uap5:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Lets the plain Win32 exe run inside the MSIX container. Auto-approved
         for desktop apps, but still a restricted capability, so it needs the
         rescap namespace. -->
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
